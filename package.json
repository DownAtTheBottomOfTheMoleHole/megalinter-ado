{
  "name": "megalinter-ado",
  "version": "1.0.0",
  "description": "MegaLinter Azure DevOps Extension",
  "author": "DownAtTheBottomOfTheMoleHole",
  "dependencies": {
    "azure-pipelines-task-lib": "5.2.10",
    "mega-linter-runner": "9.4.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.8.1",
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@types/sinon": "21.0.1",
    "eslint": "10.2.1",
    "nyc": "18.0.0",
    "prettier": "3.8.3",
    "sinon": "21.1.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DownAtTheBottomOfTheMoleHole/megalinter-ado.git"
  },
  "scripts": {
    "audit": "npm audit",
    "build": "cd megalinter && tsc",
    "clean": "rm -rf node_modules/ && rm -rf build/",
    "coverage": "nyc cucumber-js --config megalinter/cucumber.js",
    "format": "prettier --write .",
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "cucumber-js --config megalinter/cucumber.js"
  }
}
